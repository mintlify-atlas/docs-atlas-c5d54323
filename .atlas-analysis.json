{
  "projectType": "general",
  "projectName": "DefinitelyTyped",
  "projectDescription": "The community repository for high-quality TypeScript type definitions, publishing thousands of @types/* packages to npm.",
  "theme": "palm",
  "primaryColor": "#848c8e",
  "lightColor": "#11161e",
  "darkColor": "#cfd0d2",
