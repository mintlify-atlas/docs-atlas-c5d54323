      },
      {
        "tab": "Maintainer Guide",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "admin/overview",
              "admin/pr-lifecycle",
              "admin/blessings"
            ]
          },
          {
            "group": "Tools & Automation",
            "pages": [
              "admin/tools",
              "admin/bot-automation"
            ]
          }
        ]
      }
    ]
  },
  "keyFeatures": [
    "8000+ TypeScript type definition packages published as @types/* on npm",
    "Community-maintained pnpm monorepo with automated CI/CD via dtslint",
    "Automated PR lifecycle managed by dt-mergebot bot",
    "Support for multiple library versions via versioned subdirectories (e.g., /v2/)",
    "Strict TypeScript compiler checks: noImplicitAny, strictNullChecks, strictFunctionTypes",
    "dprint-based automatic code formatting",
    "Module format validation via @arethetypeswrong/cli (attw)",
    "Definition ownership system via package.json owners field"
  ],
  "publicApiSurface": [
    "@types/<package-name> — npm install --save-dev @types/node",
    "@types/<scope>__<package> — scoped package types (e.g., @types/babel__core)",
    "index.d.ts — main type declarations for each package",
    "package.json — metadata including name, version, owners, dependencies",
    "tsconfig.json — per-package TypeScript configuration",
    ".npmignore — controls which declaration files are published",
    "pnpm test <package> — run dtslint checks for a specific package",
    "npx dts-gen --dt --name <package> --template module — scaffold a new package",
    "pnpm run not-needed <name> <version> — mark a package as no longer needed"
  ]
}
